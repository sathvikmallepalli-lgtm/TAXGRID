# =============================================================================
# TaxGrid — environment variables
# Copy to `.env` and fill in. Never commit `.env`.
# Quick start (UI + proxy): npm run dev:full
# =============================================================================

# --- A) Real GST data via local proxy (recommended) ---
# Provider keys stay on the server (not in the browser bundle).
# Or: two terminals — npm run gst-proxy | npm run dev
# Vite proxies /api/gst → http://127.0.0.1:8787

GST_API_KEY=
GST_CLIENT_ID=
# GST_SEARCH_URL=https://commonapi.mastersindia.co/commonapis/searchgstin
# GST_PROXY_PORT=8787

VITE_GST_PROVIDER=proxy
# VITE_GST_PROXY_BASE=https://your-backend.example.com

# --- B) Direct browser → provider (NOT for production; VITE_* is public) ---
# VITE_GST_PROVIDER=mastersindia
# VITE_GST_API_KEY=
# VITE_GST_CLIENT_ID=

# --- C) GST System API (GSTN) — per "How To Start" / Developer Portal ---
# Get Sandbox access via an empanelled GSP: https://gstn.org.in/empanelled-gsps
# Then implement Authentication API + encryption using portal "Download" samples.
# Placeholder env names for a future GSTN server integration (not wired yet):
# GSTN_SANDBOX_BASE=https://devapi.gst.gov.in
# GSTN_CLIENT_ID=
# GSTN_CLIENT_SECRET=
# GSTN_STATE_CD=

# Demo only (no live calls)
# VITE_GST_PROVIDER=mock

# VITE_GST_TIMEOUT_MS=15000
